% neurips_2024.sty — Style file for NeurIPS 2024
% Based on the official NeurIPS style file format
% Supports options: [final], [preprint], [nonatbib]

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/01/01 NeurIPS 2024 style file]

% Declare options
\newif\if@neuripsfinal\@neuripsfinalfalse
\newif\if@neuripspreprint\@neuripspreprintfalse
\newif\if@natbib\@natbibtrue

\DeclareOption{final}{\@neuripsfinaltrue}
\DeclareOption{preprint}{\@neuripspreprinttrue}
\DeclareOption{nonatbib}{\@natbibfalse}
\ProcessOptions\relax

% Load natbib unless disabled
\if@natbib
  \RequirePackage[sort&compress,numbers,square]{natbib}
\fi

% ---- Page layout ----
\RequirePackage{geometry}
\geometry{
  textwidth=5.5in,
  textheight=9in,
  top=1in,
  headheight=12pt,
  headsep=25pt,
  footskip=30pt
}

% ---- Fonts and spacing ----
\RequirePackage{times}
\renewcommand{\rmdefault}{ptm}
\renewcommand{\sfdefault}{phv}

\linespread{1.0}
\setlength{\parindent}{0pt}
\setlength{\parskip}{5.5pt plus 1pt minus 1pt}

% ---- Abstract ----
\renewenvironment{abstract}{%
  \centerline{\large\bfseries Abstract}%
  \vspace{0.5ex}%
  \begin{quote}%
  \small
}{%
  \par
  \end{quote}%
  \vskip 1ex%
}

% ---- Title and author handling ----
\def\@maketitle{%
  \newpage
  \null
  \vskip 0.1in
  \begin{center}%
    {\LARGE\bfseries \@title \par}%
    \vskip 0.3in
    \if@neuripsfinal
      {\large
        \lineskip .5em
        \begin{tabular}[t]{c}%
          \@author
        \end{tabular}\par}%
    \else
      \if@neuripspreprint
        {\large
          \lineskip .5em
          \begin{tabular}[t]{c}%
            \@author
          \end{tabular}\par}%
      \else
        {\large Anonymous Author(s)\par}%
      \fi
    \fi
    \vskip 0.3in
  \end{center}%
  \par
  \vskip 0.2in
}

% ---- Section formatting ----
\renewcommand\section{\@startsection{section}{1}{\z@}%
  {-2.5ex \@plus -1ex \@minus -.2ex}%
  {1.3ex \@plus.2ex}%
  {\normalfont\large\bfseries}}

\renewcommand\subsection{\@startsection{subsection}{2}{\z@}%
  {-2.0ex\@plus -1ex \@minus -.2ex}%
  {1.0ex \@plus .2ex}%
  {\normalfont\normalsize\bfseries}}

\renewcommand\subsubsection{\@startsection{subsubsection}{3}{\z@}%
  {-1.5ex\@plus -1ex \@minus -.2ex}%
  {0.7ex \@plus .2ex}%
  {\normalfont\normalsize\bfseries}}

\renewcommand\paragraph{\@startsection{paragraph}{4}{\z@}%
  {1.0ex \@plus 0.5ex \@minus .2ex}%
  {-1em}%
  {\normalfont\normalsize\bfseries}}

% ---- Headers/footers ----
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\fancyhead{}
\fancyfoot[C]{\thepage}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

% First page style
\fancypagestyle{plain}{%
  \fancyhf{}
  \if@neuripsfinal
    \fancyfoot[C]{\thepage}
  \else
    \if@neuripspreprint
      \fancyfoot[C]{\thepage}
      \fancyhead[C]{Preprint. Under review.}
    \else
      \fancyfoot[C]{\thepage}
      \fancyhead[C]{Submitted to 38th Conference on Neural Information Processing Systems (NeurIPS 2024). Do not distribute.}
    \fi
  \fi
  \renewcommand{\headrulewidth}{0pt}
  \renewcommand{\footrulewidth}{0pt}
}

\thispagestyle{plain}

% ---- Footnotes ----
\renewcommand{\footnoterule}{\kern-3pt \hrule width 2in \kern 2.6pt}

% ---- Captions ----
\long\def\@makecaption#1#2{%
  \vskip\abovecaptionskip
  \sbox\@tempboxa{#1: #2}%
  \ifdim \wd\@tempboxa >\hsize
    #1: #2\par
  \else
    \global \@minipagefalse
    \hb@xt@\hsize{\hfil\box\@tempboxa\hfil}%
  \fi
  \vskip\belowcaptionskip}

% ---- Utility commands often used in NeurIPS papers ----
\newcommand{\theHalgorithm}{\arabic{algorithm}}

% ---- Acknowledgments environment ----
\newenvironment{ack}{%
  \section*{Acknowledgments}%
}{%
  \par
}

\endinput
